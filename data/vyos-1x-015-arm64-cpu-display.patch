 from jinja2 import Template
 
+# ARM CPU implementer IDs → vendor names
+_ARM_IMPLEMENTERS = {
+    '0x41': 'ARM', '0x42': 'Broadcom', '0x43': 'Cavium',
+    '0x44': 'DEC', '0x46': 'Fujitsu', '0x48': 'HiSilicon',
+    '0x4e': 'NVIDIA', '0x50': 'APM', '0x51': 'Qualcomm',
+    '0x53': 'Samsung', '0x56': 'Marvell', '0x61': 'Apple',
+    '0x69': 'Intel', '0xc0': 'Ampere',
+}
+
+# ARM CPU part numbers → core names (implementer 0x41 = ARM)
+_ARM_PARTS = {
+    '0xd03': 'Cortex-A53', '0xd04': 'Cortex-A35',
+    '0xd05': 'Cortex-A55', '0xd07': 'Cortex-A57',
+    '0xd08': 'Cortex-A72', '0xd09': 'Cortex-A73',
+    '0xd0a': 'Cortex-A75', '0xd0b': 'Cortex-A76',
+    '0xd0c': 'Neoverse-N1', '0xd0d': 'Cortex-A77',
+    '0xd40': 'Neoverse-V1', '0xd41': 'Cortex-A78',
+    '0xd44': 'Cortex-X1', '0xd46': 'Cortex-A510',
+    '0xd47': 'Cortex-A710', '0xd48': 'Cortex-X2',
+    '0xd49': 'Neoverse-N2', '0xd4d': 'Cortex-A715',
+}
+
+def _arm_model_name(cpu):
+    """Derive a human-readable model name for an ARM CPU entry."""
+    part = cpu.get('CPU part', '')
+    name = _ARM_PARTS.get(part, part if part else 'unknown')
+    impl = cpu.get('CPU implementer', '')
+    vendor = _ARM_IMPLEMENTERS.get(impl, '')
+    if vendor:
+        return f'{vendor} {name}'
+    return name
+
