[Unit]
Description=ASK fast-path conntrack fix — remove VyOS notrack rules
After=vyos-router.service
ConditionPathExists=/proc/device-tree/compatible

[Service]
Type=oneshot
ExecStart=/usr/local/bin/ask-conntrack-fix.sh
RemainAfterExit=yes
StandardOutput=journal

[Install]
WantedBy=multi-user.target