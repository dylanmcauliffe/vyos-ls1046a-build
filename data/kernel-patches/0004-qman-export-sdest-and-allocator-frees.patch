From: Beast <beast@mono-gateway.local>
Date: Wed, 26 Mar 2026 21:00:00 +0000
Subject: [PATCH 4/6] soc: fsl: qbman: Export qman_set_sdest and add
 allocator-only free functions

Export qman_set_sdest() which configures the stash destination
(SDEST) for a QMan software portal. DPDK needs this to bind
portal stash targets to specific CPU cores for optimal cache
locality. The function already exists in qman_ccsr.c — this patch
adds the EXPORT_SYMBOL.

Also add three allocator-only free functions to qman.c:
  - qman_free_fqid_range(): returns FQIDs to genalloc pool
  - qman_free_pool_range(): returns pool-channel IDs to genalloc pool
  - qman_free_cgrid_range(): returns CGRIDs to genalloc pool

Unlike the standard release functions (qman_release_fqid,
qman_release_pool, qman_release_cgrid) which perform hardware
cleanup via QBMan portals, these functions ONLY return IDs to
the allocator. This is critical for the USDPAA driver because:

1. DPDK userspace manages hardware resource lifecycle (FQ retire,
   pool drain, CGR teardown) before closing the /dev/fsl-usdpaa fd.
2. When portals are reserved for userspace, the kernel portal
   mappings are invalid — calling qman_shutdown_fq() or
   bm_shutdown_pool() from kernel context triggers a level 3
   translation fault → kernel panic.

Root cause discovered: kernel #22 crashed in qman_release_fqid →
qman_shutdown_fq → __memset during DPDK telemetry cleanup.
Fixed in kernel #23 by using these allocator-only frees.

Signed-off-by: Beast <beast@mono-gateway.local>
---
 drivers/soc/fsl/qbman/qman.c      | 36 ++++++++++++++++++++++++++++++
 drivers/soc/fsl/qbman/qman_ccsr.c |  1 +
 drivers/soc/fsl/qbman/qman_priv.h |  5 +++++
 include/soc/fsl/qman.h            |  5 +++++
 4 files changed, 47 insertions(+)

diff --git a/drivers/soc/fsl/qbman/qman_ccsr.c b/drivers/soc/fsl/qbman/qman_ccsr.c
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/qman_ccsr.c
+++ b/drivers/soc/fsl/qbman/qman_ccsr.c
@@ -XXX,6 +XXX,7 @@
 		qm_ccsr_out(REG_QCSP_IO_CFG(idx), after);
 	}
 }
+EXPORT_SYMBOL(qman_set_sdest);
 
 static int qman_resource_init(struct device *dev)
 {

diff --git a/drivers/soc/fsl/qbman/qman.c b/drivers/soc/fsl/qbman/qman.c
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/qman.c
+++ b/drivers/soc/fsl/qbman/qman.c
@@ -XXX,3 +XXX,39 @@
 	return 0;
 }
 EXPORT_SYMBOL(qman_shutdown_fq);
+
+/*
+ * Allocator-only free functions for USDPAA driver.
+ *
+ * These ONLY return IDs to the genalloc pool WITHOUT any hardware
+ * cleanup (no qman_shutdown_fq, no qpool_cleanup, no cgr_cleanup).
+ *
+ * CRITICAL: The standard release functions (qman_release_fqid,
+ * qman_release_pool, qman_release_cgrid) access QBMan portals via
+ * qman_p_irqsource_add → portal register writes. When portals are
+ * reserved for DPDK userspace, those kernel portal mappings have
+ * been memunmap'd — accessing them causes:
+ *   Unable to handle kernel paging request at virtual address ffff...
+ *   Internal error: Oops: 0000000096000007 [#1] SMP
+ *
+ * DPDK is responsible for draining/retiring its own FQs, pools,
+ * and CGRs before closing the usdpaa fd. The kernel just reclaims
+ * the ID ranges from the genalloc pools.
+ */
+void qman_free_fqid_range(u32 fqid, u32 count)
+{
+	gen_pool_free(qm_fqalloc, fqid | DPAA_GENALLOC_OFF, count);
+}
+EXPORT_SYMBOL(qman_free_fqid_range);
+
+void qman_free_pool_range(u32 qp, u32 count)
+{
+	gen_pool_free(qm_qpalloc, qp | DPAA_GENALLOC_OFF, count);
+}
+EXPORT_SYMBOL(qman_free_pool_range);
+
+void qman_free_cgrid_range(u32 cgrid, u32 count)
+{
+	gen_pool_free(qm_cgralloc, cgrid | DPAA_GENALLOC_OFF, count);
+}
+EXPORT_SYMBOL(qman_free_cgrid_range);

diff --git a/drivers/soc/fsl/qbman/qman_priv.h b/drivers/soc/fsl/qbman/qman_priv.h
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/qman_priv.h
+++ b/drivers/soc/fsl/qbman/qman_priv.h
@@ -XXX,6 +XXX,11 @@
 int qman_alloc_fqid_range(u32 *result, u32 count);
 int qman_alloc_pool_range(u32 *result, u32 count);
 int qman_alloc_cgrid_range(u32 *result, u32 count);
+
+/* Allocator-only free — no hardware cleanup (for USDPAA driver) */
+void qman_free_fqid_range(u32 fqid, u32 count);
+void qman_free_pool_range(u32 qp, u32 count);
+void qman_free_cgrid_range(u32 cgrid, u32 count);
 
 void qman_set_sdest(u16 channel, unsigned int cpu_idx);

diff --git a/include/soc/fsl/qman.h b/include/soc/fsl/qman.h
index XXXXXXX..XXXXXXX 100644
--- a/include/soc/fsl/qman.h
+++ b/include/soc/fsl/qman.h
@@ -XXX,6 +XXX,11 @@
 #define qman_alloc_cgrid(result) \
 	qman_alloc_cgrid_range(result, 1)
 
+/* Allocator-only free — no hardware cleanup (for USDPAA driver) */
+void qman_free_fqid_range(u32 fqid, u32 count);
+void qman_free_pool_range(u32 qp, u32 count);
+void qman_free_cgrid_range(u32 cgrid, u32 count);
+
 int qman_release_fqid(u32 fqid);
 
