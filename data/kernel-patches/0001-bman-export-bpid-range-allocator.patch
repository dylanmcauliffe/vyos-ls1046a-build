From: Beast <beast@mono-gateway.local>
Date: Wed, 26 Mar 2026 21:00:00 +0000
Subject: [PATCH 1/6] soc: fsl: qbman: Export BMan BPID range allocator

Export bm_alloc_bpid_range() and bm_release_bpid() for use by the
USDPAA mainline driver module. DPDK's DPAA1 PMD needs direct BPID
range allocation (not wrapped in struct bman_pool) for its buffer
pool management.

Also add bm_free_bpid_range() which only deallocates BPID IDs from
the genalloc pool WITHOUT draining the hardware buffer pool. This is
needed by the USDPAA driver because DPDK userspace manages pool
draining — calling bm_shutdown_pool() from kernel context crashes
when portals are reserved for userspace.

Signed-off-by: Beast <beast@mono-gateway.local>
---
 drivers/soc/fsl/qbman/bman.c      | 18 ++++++++++++++++--
 drivers/soc/fsl/qbman/bman_priv.h |  5 +++++
 2 files changed, 21 insertions(+), 2 deletions(-)

diff --git a/drivers/soc/fsl/qbman/bman.c b/drivers/soc/fsl/qbman/bman.c
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/bman.c
+++ b/drivers/soc/fsl/qbman/bman.c
@@ -XXX,7 +XXX,7 @@
 
 struct gen_pool *bm_bpalloc;
 
-static int bm_alloc_bpid_range(u32 *result, u32 count)
+int bm_alloc_bpid_range(u32 *result, u32 count)
 {
 	unsigned long addr;
 
@@ -XXX,8 +XXX,9 @@
 	*result = addr & ~DPAA_GENALLOC_OFF;
 	return 0;
 }
+EXPORT_SYMBOL(bm_alloc_bpid_range);
 
-static int bm_release_bpid(u32 bpid)
+int bm_release_bpid(u32 bpid)
 {
 	int ret;
 
@@ -XXX,6 +XXX,20 @@
 	gen_pool_free(bm_bpalloc, bpid | DPAA_GENALLOC_OFF, 1);
 	return 0;
 }
+EXPORT_SYMBOL(bm_release_bpid);
+
+/*
+ * bm_free_bpid_range - Free BPID IDs without hardware pool drain
+ *
+ * Unlike bm_release_bpid() which calls bm_shutdown_pool() to drain
+ * the hardware buffer pool, this function ONLY returns the IDs to
+ * the genalloc allocator. Used by USDPAA driver where userspace
+ * DPDK manages pool draining before releasing BPIDs.
+ */
+void bm_free_bpid_range(u32 bpid, u32 count)
+{
+	gen_pool_free(bm_bpalloc, bpid | DPAA_GENALLOC_OFF, count);
+}
+EXPORT_SYMBOL(bm_free_bpid_range);
 
 struct bman_pool *bman_new_pool(void)
 {
diff --git a/drivers/soc/fsl/qbman/bman_priv.h b/drivers/soc/fsl/qbman/bman_priv.h
index XXXXXXX..XXXXXXX 100644
--- a/drivers/soc/fsl/qbman/bman_priv.h
+++ b/drivers/soc/fsl/qbman/bman_priv.h
@@ -XXX,6 +XXX,11 @@
 
 extern struct gen_pool *bm_bpalloc;
 
-/* BPID range allocator — exported for USDPAA mainline driver */
+/* BPID range allocator — exported for USDPAA mainline driver
+ *
+ * bm_release_bpid: drains hardware pool, then frees ID (kernel use)
+ * bm_free_bpid_range: frees IDs only, no hardware drain (USDPAA use)
+ */
 int bm_alloc_bpid_range(u32 *result, u32 count);
 int bm_release_bpid(u32 bpid);
+void bm_free_bpid_range(u32 bpid, u32 count);
 
 struct bm_portal_config {
 	/* Portal addresses */
