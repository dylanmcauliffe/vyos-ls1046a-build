# ASK (Application-Specific Kernel) fast-path configuration
# Enables the Gillmor/Comcerto hardware flow offloading via FMan PCD
#
# Requires: ls1046a-sdk.config (SDK DPAA1 drivers)
# Applied: after ls1046a-sdk.config in the config append chain

# Core ASK fast-path
CONFIG_CPE_FAST_PATH=y

# ASK QMan portal NAPI polling (optimised packet processing)
CONFIG_FSL_ASK_QMAN_PORTAL_NAPI=y

# Netfilter fast-path modules
CONFIG_COMCERTO_FP=y
CONFIG_NETFILTER_XT_QOSMARK=y
CONFIG_NETFILTER_XT_QOSCONNMARK=y

# IPSec hardware offload (SA offload to FMan)
CONFIG_INET_IPSEC_OFFLOAD=y
CONFIG_INET6_IPSEC_OFFLOAD=y

# Conntrack procfs (required for /proc/net/nf_conntrack visibility)
CONFIG_NF_CONNTRACK_PROCFS=y
